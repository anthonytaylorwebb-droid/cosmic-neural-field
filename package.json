{
  "name": "signal-field",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "desktop:dev": "concurrently -k \"npm:dev\" \"npm:electron:dev\"",
    "electron:dev": "wait-on tcp:5173 && electron .",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "desktop:build": "npm run build && electron-builder --mac dir",
    "desktop:dist": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "systeminformation": "^5.31.4",
    "zustand": "^5.0.3"
  },
  "build": {
    "appId": "com.signalfield.app",
    "productName": "Signal Field",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [
        "dir"
      ]
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^9.0.4"
  }
}
